<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ══════════════════════════════════════════════════════
         REUSABLE COMPONENT STYLES — F1 Stats App
         Phase 1: Visual Foundation
         ══════════════════════════════════════════════════════ -->

    <!-- ── Cards ─────────────────────────────────────────── -->

    <!-- Hero card: next race, champion spotlight (flat, no elevation) -->
    <style name="Widget.F1.Card.Hero" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Standard card: used sparingly for genuinely card-shaped content -->
    <style name="Widget.F1.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">@dimen/card_corner_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- ── List Rows ──────────────────────────────────────── -->

    <!-- Standard list row: driver standings, race results, etc. -->
    <style name="Widget.F1.ListRow" parent="">
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:paddingStart">@dimen/spacing_md</item>
        <item name="android:paddingEnd">@dimen/spacing_md</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:minHeight">56dp</item>
    </style>

    <!-- ── Sections ───────────────────────────────────────── -->

    <!-- Section eyebrow label: ALL-CAPS metadata above a content block -->
    <style name="Widget.F1.SectionLabel" parent="">
        <item name="android:textAppearance">@style/TextAppearance.F1.Label</item>
        <item name="android:layout_marginTop">@dimen/spacing_lg</item>
        <item name="android:layout_marginBottom">@dimen/spacing_sm</item>
    </style>

    <!-- Section divider: thin horizontal rule between content groups -->
    <style name="Widget.F1.Divider" parent="">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">@color/bg_elevated</item>
    </style>

    <!-- ── Team Accent Strip ──────────────────────────────── -->

    <!-- Left edge team colour strip: use in driver/result rows -->
    <style name="Widget.F1.TeamStrip" parent="">
        <item name="android:layout_width">@dimen/team_strip_width</item>
        <item name="android:layout_height">match_parent</item>
        <item name="android:background">@color/team_default</item>
    </style>

    <!-- ── Stat Display ───────────────────────────────────── -->

    <!-- Large numeric stat value (points, laps, etc.) -->
    <style name="Widget.F1.StatValue" parent="">
        <item name="android:textAppearance">@style/TextAppearance.F1.CardHeader</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:gravity">end</item>
    </style>

    <!-- Supporting stat label beneath a StatValue -->
    <style name="Widget.F1.StatLabel" parent="">
        <item name="android:textAppearance">@style/TextAppearance.F1.Metadata</item>
        <item name="android:gravity">end</item>
    </style>

    <!-- ── Hero Number ────────────────────────────────────── -->

    <!-- Large countdown / gap display (48sp, accent-colored) -->
    <style name="Widget.F1.HeroNumber" parent="">
        <item name="android:textAppearance">@style/TextAppearance.F1.Hero</item>
        <item name="android:textColor">@color/f1_red</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ── Tab Layout ─────────────────────────────────────── -->

    <style name="Widget.F1.TabLayout" parent="Widget.Material3.TabLayout">
        <item name="tabTextAppearance">@style/TabTextAppearance</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/text_primary</item>
        <item name="tabIndicatorColor">@color/f1_red</item>
        <item name="tabIndicatorHeight">2dp</item>
        <item name="android:background">@color/bg_surface</item>
    </style>

    <!-- ── Buttons ────────────────────────────────────────── -->

    <style name="Widget.F1.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/f1_red</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- ── Badge ──────────────────────────────────────────── -->

    <!-- Compact status badge (NEXT RACE, LAST WINNER, etc.) -->
    <style name="Widget.F1.Badge" parent="">
        <item name="android:textAppearance">@style/TextAppearance.F1.Label</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:paddingStart">6dp</item>
        <item name="android:paddingEnd">6dp</item>
        <item name="android:paddingTop">3dp</item>
        <item name="android:paddingBottom">3dp</item>
        <item name="android:background">@drawable/bg_badge_red</item>
    </style>

</resources>
