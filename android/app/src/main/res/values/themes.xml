<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── App Theme ──────────────────────────────────────── -->
    <style name="Theme.F1Stats" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/f1_red</item>
        <item name="colorPrimaryVariant">#A10400</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/white</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <!-- ── Typography Hierarchy ───────────────────────────── -->

    <!-- Hero: race countdowns, championship gaps, race-day numbers -->
    <style name="TextAppearance.F1.Hero" parent="TextAppearance.Material3.DisplaySmall">
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

    <!-- Section Header: screen-level section labels (24sp) -->
    <style name="TextAppearance.F1.SectionHeader" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Card Header: card/item primary name labels (18sp) -->
    <style name="TextAppearance.F1.CardHeader" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Body: standard readable content (15sp) -->
    <style name="TextAppearance.F1.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- Metadata: secondary labels, dates, team names (12sp) -->
    <style name="TextAppearance.F1.Metadata" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Label: ALL-CAPS micro-labels, section eyebrows (10sp) -->
    <style name="TextAppearance.F1.Label" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:letterSpacing">0.12</item>
        <item name="textAllCaps">true</item>
    </style>

    <!-- ── Component Styles ───────────────────────────────── -->

    <style name="TabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">13sp</item>
        <item name="textAllCaps">false</item>
    </style>

    <style name="ShapeAppearance.Circle" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- ── Splash ─────────────────────────────────────────── -->
    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/bg_dark</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.F1Stats</item>
    </style>

</resources>
