        <item name="colorPrimary">#E10600</item>
        <item name="colorPrimaryVariant">#A10400</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Secondary -->
        <item name="colorSecondary">#FFFFFF</item>
