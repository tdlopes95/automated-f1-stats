<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.F1Stats" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">#E10600</item>
        <item name="colorPrimaryVariant">#A10400</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#FFFFFF</item>
        <item name="colorOnSecondary">#000000</item>
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:navigationBarColor">#1E1E1E</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
    </style>

    <style name="Theme.App.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#E10600</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.F1Stats</item>
    </style>
</resources>