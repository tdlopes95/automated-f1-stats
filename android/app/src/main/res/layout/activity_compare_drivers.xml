<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_toolbar"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Season picker -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bg_surface"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:gravity="center_vertical|end"
                android:layout_marginBottom="8dp">

                <ImageButton
                    android:id="@+id/btn_prev_year"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_chevron_left"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Previous year"
                    android:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tv_selected_year"
                    android:layout_width="52dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageButton
                    android:id="@+id/btn_next_year"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_chevron_right"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Next year"
                    android:tint="@color/text_secondary" />

            </LinearLayout>

            <!-- Driver selection -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@color/bg_surface"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <!-- Driver 1 -->
                <LinearLayout
                    android:id="@+id/btn_select_driver1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/iv_headshot1"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_headshot_placeholder"/>

                    <TextView
                        android:id="@+id/tv_driver1_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to select"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tv_driver1_team"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

                <!-- VS label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VS"
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:layout_gravity="center_vertical"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"/>

                <!-- Driver 2 -->
                <LinearLayout
                    android:id="@+id/btn_select_driver2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/iv_headshot2"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:scaleType="centerCrop"
                        android:background="@drawable/bg_headshot_placeholder"/>

                    <TextView
                        android:id="@+id/tv_driver2_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap to select"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:gravity="center"
                        android:layout_marginTop="8dp"/>

                    <TextView
                        android:id="@+id/tv_driver2_team"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:gravity="center"
                        android:layout_marginTop="2dp"
                        android:visibility="gone"/>

                </LinearLayout>

            </LinearLayout>

            <!-- Loading indicator -->
            <ProgressBar
                android:id="@+id/pb_loading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="32dp"
                android:visibility="gone"/>

            <!-- Season comparison stats -->
            <LinearLayout
                android:id="@+id/section_stats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@color/bg_surface"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Season Comparison"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bg_divider"/>

                <LinearLayout
                    android:id="@+id/ll_stats_rows"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>

            </LinearLayout>

            <!-- Head-to-Head -->
            <LinearLayout
                android:id="@+id/section_h2h"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:background="@color/bg_surface"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Head-to-Head"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:padding="16dp"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/bg_divider"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="When both finished a race"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tv_h2h_d1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_primary"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:gravity="end"
                            android:paddingEnd="20dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="–"
                            android:textColor="@color/text_secondary"
                            android:textSize="24sp"/>

                        <TextView
                            android:id="@+id/tv_h2h_d2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_primary"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:gravity="start"
                            android:paddingStart="20dp"/>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="10dp"
                        android:orientation="horizontal">

                        <View
                            android:id="@+id/view_h2h_d1_bar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"/>

                        <View
                            android:id="@+id/view_h2h_d2_bar"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
