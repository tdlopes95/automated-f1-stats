<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <!-- Skeleton shown while loading -->
    <include
        layout="@layout/fragment_home_skeleton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible" />

    <!-- Error state -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="gone">

        <TextView
            android:text="⚠️"
            android:textSize="48sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center" />

        <TextView
            android:id="@+id/tv_error_message"
            android:text="Could not load data.\nCheck your connection."
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textAlignment="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Retry"
            android:layout_marginTop="24dp"
            style="@style/Widget.Material3.Button"
            android:backgroundTint="@color/f1_red" />

    </LinearLayout>

    <!-- Real content -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_home"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/scroll_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="16dp">

                <!-- ── Next Race Card ──────────────────────────────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_next_race"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Hero image with gradient overlay and race name -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="140dp">

                            <ImageView
                                android:id="@+id/iv_next_race_circuit"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:background="@color/bg_dark" />

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/gradient_bottom_dark" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="bottom"
                                android:orientation="vertical"
                                android:paddingStart="14dp"
                                android:paddingEnd="14dp"
                                android:paddingBottom="12dp">

                                <TextView
                                    android:text="NEXT RACE"
                                    android:textColor="@color/f1_red"
                                    android:textSize="10sp"
                                    android:letterSpacing="0.12"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal"
                                    android:gravity="center_vertical"
                                    android:layout_marginTop="2dp">

                                    <TextView
                                        android:id="@+id/tv_next_race_flag"
                                        android:text=""
                                        android:textSize="18sp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginEnd="7dp" />

                                    <TextView
                                        android:id="@+id/tv_next_race_name"
                                        android:text=""
                                        android:textColor="@color/text_primary"
                                        android:textSize="20sp"
                                        android:textStyle="bold"
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:maxLines="1"
                                        android:ellipsize="end" />

                                </LinearLayout>

                            </LinearLayout>

                        </FrameLayout>

                        <!-- Content below image -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tv_next_race_circuit"
                                android:text=""
                                android:textColor="@color/text_hint"
                                android:textSize="13sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                            <TextView
                                android:id="@+id/tv_next_race_date"
                                android:text=""
                                android:textColor="@color/text_secondary"
                                android:textSize="13sp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" />

                            <TextView
                                android:id="@+id/tv_countdown"
                                android:text=""
                                android:textColor="@color/f1_red"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="10dp" />

                            <!-- Session times rows injected here -->
                            <LinearLayout
                                android:id="@+id/ll_session_times"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:layout_marginTop="10dp" />

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Championship Leader Card ────────────────────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_leader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Team colour accent strip -->
                        <View
                            android:id="@+id/view_leader_colour"
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="@color/text_hint" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <TextView
                                android:id="@+id/tv_leader_title"
                                android:text="CHAMPIONSHIP LEADER"
                                android:textColor="@color/f1_red"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="10dp">

                                <ImageView
                                    android:id="@+id/iv_leader_headshot"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:scaleType="centerCrop"
                                    android:background="@color/bg_dark" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:id="@+id/tv_leader_name"
                                        android:text=""
                                        android:textColor="@color/text_primary"
                                        android:textSize="17sp"
                                        android:textStyle="bold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content" />

                                    <TextView
                                        android:id="@+id/tv_leader_team"
                                        android:text=""
                                        android:textColor="@color/text_secondary"
                                        android:textSize="13sp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp" />

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="horizontal"
                                        android:gravity="center_vertical"
                                        android:layout_marginTop="4dp">

                                        <TextView
                                            android:id="@+id/tv_leader_points"
                                            android:text=""
                                            android:textColor="@color/text_primary"
                                            android:textSize="20sp"
                                            android:textStyle="bold"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content" />

                                        <TextView
                                            android:id="@+id/tv_leader_gap"
                                            android:text=""
                                            android:textColor="@color/color_race_live"
                                            android:textSize="12sp"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:visibility="gone" />

                                    </LinearLayout>

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Last Race Winner Card ───────────────────────────── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_last_race"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/bg_surface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Team colour accent strip -->
                        <View
                            android:id="@+id/view_last_winner_colour"
                            android:layout_width="4dp"
                            android:layout_height="match_parent"
                            android:background="@color/text_hint" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:padding="16dp">

                            <!-- LAST WINNER badge -->
                            <TextView
                                android:text="LAST WINNER"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp"
                                android:letterSpacing="0.12"
                                android:paddingStart="7dp"
                                android:paddingEnd="7dp"
                                android:paddingTop="3dp"
                                android:paddingBottom="3dp"
                                android:background="@drawable/bg_badge_red"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginTop="10dp">

                                <ImageView
                                    android:id="@+id/iv_last_winner_headshot"
                                    android:layout_width="48dp"
                                    android:layout_height="48dp"
                                    android:scaleType="centerCrop"
                                    android:background="@color/bg_dark" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical"
                                    android:layout_marginStart="12dp">

                                    <TextView
                                        android:id="@+id/tv_last_winner"
                                        android:text=""
                                        android:textColor="@color/text_primary"
                                        android:textSize="17sp"
                                        android:textStyle="bold"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content" />

                                    <TextView
                                        android:id="@+id/tv_last_race_team"
                                        android:text=""
                                        android:textColor="@color/text_secondary"
                                        android:textSize="13sp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp" />

                                    <TextView
                                        android:id="@+id/tv_last_race_name"
                                        android:text=""
                                        android:textColor="@color/text_hint"
                                        android:textSize="12sp"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="2dp" />

                                </LinearLayout>

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>
    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</FrameLayout>
