<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Tab row: Drivers / Constructors / Pit Stops -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_standings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/Widget.F1.TabLayout" />

    <!-- Season picker + compare button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/bg_surface"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/spacing_sm"
        android:paddingTop="@dimen/spacing_xs"
        android:paddingBottom="@dimen/spacing_xs"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_compare_drivers"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_compare"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Compare Drivers"
            android:tint="@color/text_secondary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btn_prev_year"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Previous year"
            android:tint="@color/text_secondary" />

        <TextView
            android:id="@+id/tv_selected_year"
            android:layout_width="52dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_subheading"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btn_next_year"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_chevron_right"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Next year"
            android:tint="@color/text_secondary" />

    </LinearLayout>

    <!-- 1dp divider between toolbar and list -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/bg_elevated" />

    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_standings"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_standings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="100dp"
                android:layoutAnimation="@anim/layout_fall_down" />

            <TextView
                android:id="@+id/tv_empty_standings"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:visibility="gone" />

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

</LinearLayout>
