<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/bg_dark">

    <TextView
        android:text="SETTINGS"
        android:textColor="@color/f1_red"
        android:textSize="11sp"
        android:letterSpacing="0.1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp" />

    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Backend URL"
        app:boxBackgroundColor="@color/bg_surface"
        app:hintTextColor="@color/text_secondary"
        app:boxStrokeColor="@color/f1_red"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_base_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:inputType="textUri"
            android:singleLine="true" />

    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:text="Include full URL with https:// — no trailing slash needed."
        android:textColor="@color/text_hint"
        android:textSize="12sp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_save_url"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save URL"
        android:layout_marginTop="24dp"
        style="@style/Widget.Material3.Button"
        android:backgroundTint="@color/f1_red" />

</LinearLayout>