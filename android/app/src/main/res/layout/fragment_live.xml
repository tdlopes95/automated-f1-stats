<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipe_refresh_weekend"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/bg_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_row"
            android:paddingBottom="@dimen/spacing_lg">

            <!-- ── Main Card: Next Session or Latest Results ─────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_main"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_row"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Circuit image -->
                    <ImageView
                        android:id="@+id/iv_circuit_image"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:scaleType="centerCrop"
                        android:background="@color/bg_shimmer" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">

                        <!-- Flag + Race Name -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <ImageView
                                android:id="@+id/iv_country_flag"
                                android:layout_width="28dp"
                                android:layout_height="20dp"
                                android:scaleType="fitCenter"
                                android:layout_marginEnd="@dimen/spacing_sm" />

                            <TextView
                                android:id="@+id/tv_race_name"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_card_header"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Session label badge (NEXT / JUST ENDED) -->
                        <TextView
                            android:id="@+id/tv_session_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="6dp"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_small"
                            android:textStyle="bold"
                            android:paddingHorizontal="@dimen/spacing_sm"
                            android:paddingVertical="3dp"
                            android:background="@color/f1_red" />

                        <!-- Session name -->
                        <TextView
                            android:id="@+id/tv_session_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_sm"
                            android:layout_marginBottom="@dimen/spacing_sm" />

                        <!-- Countdown (shown for upcoming sessions) -->
                        <TextView
                            android:id="@+id/tv_countdown"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/f1_red"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:layout_marginBottom="@dimen/spacing_xs"
                            android:visibility="gone" />

                        <!-- Local start/end time -->
                        <TextView
                            android:id="@+id/tv_local_time"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_caption"
                            android:layout_marginBottom="@dimen/spacing_row"
                            android:visibility="gone" />

                        <!-- Quick results (top 10, shown after a result session) -->
                        <LinearLayout
                            android:id="@+id/ll_quick_results"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:visibility="gone"
                            android:layout_marginBottom="@dimen/spacing_row" />

                        <!-- Open full results button -->
                        <TextView
                            android:id="@+id/btn_open_results"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:text="VIEW FULL RESULTS"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_metadata"
                            android:textStyle="bold"
                            android:gravity="center"
                            android:background="@color/bg_divider"
                            android:visibility="gone" />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Weekend Timeline Card ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_timeline"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tv_timeline_header"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="RACE WEEKEND"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_small"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="@dimen/spacing_row" />

                    <LinearLayout
                        android:id="@+id/ll_sessions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Empty / loading state -->
            <TextView
                android:id="@+id/tv_empty_weekend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body"
                android:padding="@dimen/spacing_xxl"
                android:text="Loading schedule..."
                android:visibility="visible" />

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
