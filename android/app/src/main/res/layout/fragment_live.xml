<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark">

    <!-- Status Banner (GREEN FLAG / SAFETY CAR / RED FLAG etc) -->
    <TextView
        android:id="@+id/tv_session_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LIVE"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"
        android:background="@color/status_green" />

    <!-- Session name + weather row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_session_name"
            android:text="Race"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_weather"
            android:text=""
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

    </LinearLayout>

    <!-- Column headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="6dp">

        <TextView android:text="POS" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:layout_width="32dp"
            android:layout_height="wrap_content" />
        <TextView android:text="DRIVER" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:layout_width="0dp"
            android:layout_height="wrap_content" android:layout_weight="1" />
        <TextView android:text="GAP" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:layout_width="72dp"
            android:layout_height="wrap_content" android:gravity="end" />
        <TextView android:text="TYRE" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:layout_width="40dp"
            android:layout_height="wrap_content" android:gravity="center" />
        <TextView android:text="PIT" android:textColor="@color/text_secondary"
            android:textSize="11sp" android:layout_width="30dp"
            android:layout_height="wrap_content" android:gravity="center" />

    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/bg_divider" />

    <!-- Driver list -->
    <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
        android:id="@+id/swipe_refresh_live"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_live_drivers"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingBottom="8dp" />

            <TextView
                android:id="@+id/tv_empty_live"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:text="No live session right now.\nCheck back during a race weekend!"
                android:visibility="gone" />

        </FrameLayout>

    </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    <!-- Last updated -->
    <TextView
        android:id="@+id/tv_last_updated"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Last updated: --"
        android:textColor="@color/text_disabled"
        android:textSize="11sp"
        android:gravity="center"
        android:padding="6dp" />

</LinearLayout>