<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_row"
    android:paddingBottom="@dimen/spacing_row"
    android:gravity="center_vertical"
    android:minHeight="56dp">

    <!-- Position -->
    <TextView
        android:id="@+id/tv_position"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body_sm" />

    <!-- Team colour strip -->
    <View
        android:id="@+id/view_team_colour"
        android:layout_width="@dimen/team_strip_width"
        android:layout_height="36dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@color/team_default" />

    <!-- Flag + name + team -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Flag + name row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_flag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🇬🇧"
                android:textSize="@dimen/text_body_sm"
                android:layout_marginEnd="@dimen/spacing_xs" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lando Norris"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="#4"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_metadata"
                android:layout_marginStart="6dp" />

        </LinearLayout>

        <!-- Team + DNF row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/tv_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="McLaren"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_metadata" />

            <TextView
                android:id="@+id/tv_dnf"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/color_eliminated"
                android:textSize="@dimen/text_small"
                android:layout_marginStart="@dimen/spacing_sm"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>

    <!-- Points + wins -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="423"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_card_header"
            android:textStyle="bold"
            android:gravity="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_wins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 wins"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_small"
                android:gravity="end" />

            <TextView
                android:id="@+id/tv_podiums"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/status_yellow"
                android:textSize="@dimen/text_small"
                android:layout_marginStart="6dp"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
