<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <!-- Toolbar with back button -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_surface"
        app:titleTextColor="@color/text_primary"
        app:subtitleTextColor="@color/text_secondary"
        app:navigationIcon="@drawable/ic_back" />

    <!-- Country flag header -->
    <LinearLayout
        android:id="@+id/ll_flag_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@color/bg_surface"
        android:visibility="gone">

        <ImageView
            android:id="@+id/iv_country_flag"
            android:layout_width="28dp"
            android:layout_height="20dp"
            android:scaleType="fitCenter" />

    </LinearLayout>

    <!-- Circuit map header -->
    <ImageView
        android:id="@+id/iv_track_map"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:scaleType="fitCenter"
        android:padding="16dp"
        android:background="@color/bg_surface"
        android:visibility="gone" />

    <!-- Weather bar -->
    <LinearLayout
        android:id="@+id/ll_weather_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="@color/bg_surface"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_weather_air"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_weather_track"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_weather_humidity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_weather_rain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_weather_wind"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

    </LinearLayout>

    <!-- Session tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout_detail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_surface"
        app:tabTextColor="@color/text_secondary"
        app:tabSelectedTextColor="@color/text_primary"
        app:tabIndicatorColor="@color/f1_red"
        app:tabIndicatorFullWidth="false"
        app:tabMode="scrollable"
        app:tabGravity="start"
        app:tabPaddingStart="12dp"
        app:tabPaddingEnd="12dp"
        app:tabTextAppearance="@style/TabTextAppearance" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A2A" />

    <!-- Sticky strategy header (legend + lap axis) -->
    <LinearLayout
        android:id="@+id/ll_strategy_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/bg_surface"
        android:visibility="gone">

        <!-- Legend row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="2dp"
            android:gravity="center_vertical">

            <!-- spacer matching finish-pos col (28dp) + driver col (46dp) -->
            <View android:layout_width="74dp" android:layout_height="1dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View android:id="@+id/strategy_dot_soft"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:layout_marginEnd="3dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="S" android:textColor="@color/text_hint" android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <View android:id="@+id/strategy_dot_medium"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:layout_marginEnd="3dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="M" android:textColor="@color/text_hint" android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <View android:id="@+id/strategy_dot_hard"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:layout_marginEnd="3dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="H" android:textColor="@color/text_hint" android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <View android:id="@+id/strategy_dot_inter"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:layout_marginEnd="3dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="I" android:textColor="@color/text_hint" android:textSize="10sp"
                    android:layout_marginEnd="8dp" />

                <View android:id="@+id/strategy_dot_wet"
                    android:layout_width="8dp" android:layout_height="8dp"
                    android:layout_marginEnd="3dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="W" android:textColor="@color/text_hint" android:textSize="10sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Lap axis row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="4dp">

            <View android:layout_width="80dp" android:layout_height="1dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lap 1"
                android:textColor="@color/text_hint"
                android:textSize="9sp" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_lap_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lap ?"
                android:textColor="@color/text_hint"
                android:textSize="9sp" />

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#1AFFFFFF" />

    </LinearLayout>

    <!-- Content area: RecyclerView tabs or Grid tab -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipe_refresh_detail"
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_round_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="8dp"
                android:paddingBottom="8dp"
                android:layoutAnimation="@anim/layout_fall_down" />

        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

        <ScrollView
            android:id="@+id/sv_grid"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/ll_grid_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp" />

        </ScrollView>

        <TextView
            android:id="@+id/tv_strategy_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="No strategy data available for this race.\nStrategy data is only available from the 2023 season onwards."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:gravity="center"
            android:padding="32dp"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>