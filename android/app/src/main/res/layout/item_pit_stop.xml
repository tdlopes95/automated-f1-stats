<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingStart="@dimen/spacing_row"
    android:paddingEnd="@dimen/spacing_row"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:gravity="center_vertical">

    <!-- Rank -->
    <TextView
        android:id="@+id/tv_rank"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_body_sm" />

    <!-- Team colour strip -->
    <View
        android:id="@+id/view_team_colour"
        android:layout_width="4dp"
        android:layout_height="36dp"
        android:layout_marginEnd="10dp"
        android:background="@color/text_primary" />

    <!-- Driver + team -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_driver_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Verstappen"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body_sm"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Red Bull Racing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small" />

    </LinearLayout>

    <!-- Lap number -->
    <TextView
        android:id="@+id/tv_lap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lap 24"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_metadata"
        android:layout_marginEnd="@dimen/spacing_row" />

    <!-- Stop duration -->
    <TextView
        android:id="@+id/tv_duration"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="2.345s"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_subheading"
        android:textStyle="bold" />

</LinearLayout>