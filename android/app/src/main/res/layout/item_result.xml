<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="?attr/selectableItemBackground"
    android:paddingStart="@dimen/spacing_md"
    android:paddingEnd="@dimen/spacing_md"
    android:paddingTop="@dimen/spacing_row"
    android:paddingBottom="@dimen/spacing_row"
    android:gravity="center_vertical"
    android:minHeight="56dp">

    <!-- Team colour strip -->
    <View
        android:id="@+id/view_team_colour"
        android:layout_width="@dimen/team_strip_width"
        android:layout_height="32dp"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="@color/team_default" />

    <!-- Position -->
    <TextView
        android:id="@+id/tv_position"
        android:layout_width="28dp"
        android:layout_height="wrap_content"
        android:text="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_body"
        android:textStyle="bold" />

    <!-- Driver + team -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_driver_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Max Verstappen"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body_sm"
                android:textStyle="bold" />

            <!-- Fastest lap indicator -->
            <TextView
                android:id="@+id/tv_fastest_lap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="⚡"
                android:textSize="@dimen/text_metadata"
                android:visibility="gone" />

        </LinearLayout>

        <TextView
            android:id="@+id/tv_team_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Red Bull Racing"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <!-- Time / Gap / Fastest Lap / Points -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tv_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1:32:05.637"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_caption"
            android:gravity="end" />

        <TextView
            android:id="@+id/tv_fastest_lap_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="@color/color_fastest_lap"
            android:textSize="@dimen/text_small"
            android:gravity="end" />

        <TextView
            android:id="@+id/tv_points"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="25 pts"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_small"
            android:gravity="end" />

    </LinearLayout>

</LinearLayout>
