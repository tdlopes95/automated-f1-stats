<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_toolbar"
        app:titleTextColor="@color/text_primary"
        app:subtitleTextColor="@color/text_secondary"
        app:navigationIcon="@drawable/ic_back" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Interactive SVG track map (WebView, shown when bundled SVG exists) -->
            <WebView
                android:id="@+id/web_track_map"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="300dp"
                android:visibility="gone"
                android:background="@color/bg_surface" />

            <!-- Fallback: hero circuit image from OpenF1 (shown when no bundled SVG) -->
            <FrameLayout
                android:id="@+id/fl_hero"
                android:layout_width="match_parent"
                android:layout_height="260dp"
                android:background="@color/bg_surface"
                android:clipChildren="true">

                <ImageView
                    android:id="@+id/iv_hero_image"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:padding="@dimen/spacing_md"
                    android:contentDescription="Circuit map" />

            </FrameLayout>

            <!-- Track info card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_row"
                android:layout_marginEnd="@dimen/spacing_row"
                android:layout_marginTop="@dimen/spacing_row"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:id="@+id/tv_circuit_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_display"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/iv_country_flag"
                            android:layout_width="28dp"
                            android:layout_height="20dp"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:visibility="gone" />

                        <TextView
                            android:id="@+id/tv_location"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_sm" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Track stats card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/spacing_row"
                android:layout_marginEnd="@dimen/spacing_row"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_row"
                app:cardBackgroundColor="@color/bg_surface"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <!-- Loading indicator -->
                    <ProgressBar
                        android:id="@+id/pb_stats_loading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:visibility="gone" />

                    <!-- Total Races + First GP row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TOTAL RACES"
                                android:textColor="@color/text_hint"
                                android:textSize="@dimen/text_small"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tv_total_races"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="FIRST GP"
                                android:textColor="@color/text_hint"
                                android:textSize="@dimen/text_small"
                                android:letterSpacing="0.08"
                                android:layout_marginBottom="2dp" />

                            <TextView
                                android:id="@+id/tv_first_gp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="—"
                                android:textColor="@color/text_primary"
                                android:textSize="@dimen/text_title"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_divider"
                        android:layout_marginTop="@dimen/spacing_row"
                        android:layout_marginBottom="@dimen/spacing_row" />

                    <!-- Most Wins -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOST WINS"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_most_wins_driver"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_most_wins_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/f1_red"
                            android:textSize="@dimen/text_body_sm"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_divider"
                        android:layout_marginTop="@dimen/spacing_row"
                        android:layout_marginBottom="@dimen/spacing_row" />

                    <!-- Most Poles -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOST POLES"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_most_poles_driver"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_most_poles_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/f1_red"
                            android:textSize="@dimen/text_body_sm"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_divider"
                        android:layout_marginTop="@dimen/spacing_row"
                        android:layout_marginBottom="@dimen/spacing_row" />

                    <!-- Most Constructor Wins -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MOST CONSTRUCTOR WINS"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_top_constructor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="—"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_top_constructor_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/f1_red"
                            android:textSize="@dimen/text_body_sm"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/bg_divider"
                        android:layout_marginTop="@dimen/spacing_row"
                        android:layout_marginBottom="@dimen/spacing_row" />

                    <!-- Lap Record -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LAP RECORD"
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_small"
                        android:letterSpacing="0.08"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <TextView
                        android:id="@+id/tv_lap_record_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_card_header"
                        android:textStyle="bold"
                        android:fontFamily="monospace" />

                    <TextView
                        android:id="@+id/tv_lap_record_driver"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_metadata"
                        android:layout_marginTop="2dp" />

                    <!-- Error state -->
                    <TextView
                        android:id="@+id/tv_stats_error"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/text_hint"
                        android:textSize="@dimen/text_caption"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
